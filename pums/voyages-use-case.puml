@startuml voyages-use-case
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #FEF3E2
skinparam usecaseBorderColor #ED5623
skinparam usecaseFontSize 13
skinparam actorFontSize 13
skinparam packageBorderColor #ED5623
skinparam packageFontSize 14

actor "Agent de livraison" as Agent
actor "Chauffeur" as Chauffeur

rectangle "Module Voyages" #FEF9F4 {
  usecase "Lister les voyages" as UC1
  usecase "Consulter les détails\nd'un voyage" as UC2
  usecase "Créer un voyage" as UC3
  usecase "Modifier un voyage" as UC4
  usecase "Supprimer un voyage" as UC5
  usecase "Clôturer un BL" as UC6
  usecase "Achever un voyage" as UC7

  usecase "Rechercher un voyage" as UC8
  usecase "Filtrer les voyages" as UC9
  usecase "Sélectionner des BLs" as UC10
  usecase "Prendre des photos\ndes BLs" as UC11
  usecase "Consulter les images\nd'un BL" as UC12
}

Agent --> UC1
Agent --> UC2
Agent --> UC3
Agent --> UC4
Agent --> UC5
Agent --> UC7

Chauffeur --> UC1
Chauffeur --> UC2
Chauffeur --> UC6

UC1 ..> UC8 : <<extend>>
UC1 ..> UC9 : <<extend>>
UC3 ..> UC10 : <<include>>
UC3 ..> UC11 : <<include>>
UC4 ..> UC10 : <<include>>
UC4 ..> UC11 : <<include>>
UC6 ..> UC12 : <<include>>

@enduml